#!/bin/bash
set -euo pipefail

TARGET="{{ .chezmoi.destDir }}/.ssh/authorized_keys"
SOURCE="{{ .chezmoi.sourceDir }}/dot_ssh/authorized_keys_content.age"

# Decrypt to a temp file
TMPFILE=$(mktemp)
trap 'rm -f "$TMPFILE"' EXIT

touch $TARGET
chmod 600 $TARGET

chezmoi decrypt --output "$TMPFILE" "$SOURCE"

# For each line in the decrypted file, append if not already present
while IFS= read -r line; do
	# Skip empty lines and comments
	[[ -z "$line" || "$line" == \#* ]] && continue

	if ! grep -qF "$line" "$TARGET"; then
		echo "$line" >> "$TARGET"
	fi
done < "$TMPFILE"
