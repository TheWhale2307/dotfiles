# +-------------------+
# | Nano Main Options |
# +-------------------+

# Make 'nextword' (Ctrl+Right) and 'chopwordright' (Ctrl+Delete) stop at word ends instead of at beginnings.
set afterends

# Enable soft line wrapping and make it wrap lines at blanks (tabs and spaces) instead of always at the edge of the screen.
set softwrap
set atblanks

# Automatically indent a newly created line to the same number of tabs and/or spaces as the preceding line -- or as the next line if the preceding line is the beginning of a paragraph.
set autoindent

# Interpret digits given on the command line after a colon after a filename as the line number and column to go to in that file.
set colonparsing

# Display a "scrollbar" on the righthand side of the edit window.
set indicator

# Display line numbers to the left (and any anchors in the margin).
set linenumbers

# Fall back to slow libmagic to try and determine an applicable syntax.
set magic

# Enable mouse support, if available for your system.  When enabled, mouse clicks can be used to place the cursor, set the mark (with two clicks), and execute shortcuts. The mouse will work in the X Window System, and on the console when gpm is running.
set mouse

# Don't display the helpful shortcut lists at the bottom of the screen.
#set nohelp

# Remember the position of cursor and anchors for the next editing session.
set positionlog

# Make status-bar messages disappear after 1 keystroke instead of after 20.
set quickblank

# Use this tab size instead of the default; it must be greater than 0.
set tabsize 4

# Let an unmodified Backspace or Delete erase the marked region (instead of a single character, and without affecting the cutbuffer).
set zap

