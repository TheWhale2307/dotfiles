# Just be a bit more polite to the shell
# Stolen from someone on reddit
function pls(){
	if [ "$#" -eq 0 ]; then # Check if no arguments are given
		sudo $(fc -ln -1) # Execute previous command with sudo
	else
		sudo $@ # Alias 'please' -> 'sudo' if arguments are given
	fi
}

