# Update the entire system with the main package manager (and flatpak)
uu() {
	{{ if (or (eq .chezmoi.osRelease.id "arch") (and (hasKey .chezmoi.osRelease "idLike") (eq .chezmoi.osRelease.idLike "arch"))) -}}
	printf "\n\033[53;4m--- Paru ---\033[0m\n\n"
	paru -Syu
	if command -v "flatpak" >/dev/null 2>&1; then
		printf "\n\033[53;4m--- Flatpak ---\033[0m\n\n"
		flatpak update -y
	fi
	{{ else if eq .chezmoi.osRelease.id "debian" -}}
	printf "\n\033[53;4m--- APT ---\033[0m\n\n"
	sudo apt update
	sudo apt upgrade -y
	{{- end }}
}

