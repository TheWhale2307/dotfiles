# Open tldr page when argument is given, fuzzy seach when run without arguments
# Uses "command" to prevent recursive alias expansion and actually call /usr/bin/tldr
tldr() {
	if [ "$#" -eq 0 ]; then
		command tldr --list | fzf --preview "command tldr {} --color always" | xargs -r tldr
	else
		command tldr $@
	fi
}

yt-dlp() {
	if [ "$#" -eq 1 ]; then
		# If given exactly one argument, download that video in mp4 by default
		command yt-dlp -t mp4 $@
	else
		command yt-dlp $@
	fi
}

cputest() {
	stress --cpu $(nproc)
}

fastfetch() {

	{{ if (or (eq .chezmoi.osRelease.id "arch") (and (hasKey .chezmoi.osRelease "idLike") (eq .chezmoi.osRelease.idLike "arch"))) -}}
	# Give a bit more weight to arch and the cool wolf from darkos
	logos=("arch2" "arch2" "arch2" "darkos" "darkos" "darkos" "locos" "locos" "sulin" "sulin")
	{{ else if eq .chezmoi.osRelease.id "debian" -}}
	logos=("debian")
	{{ end -}}

	# Indexing works fine for most shells, including bash, zsh arrays start at 1 however
	if [[ -n "$ZSH_VERSION" ]]; then
		command fastfetch -l "${logos[$(($RANDOM % ${#logos[@]} + 1))]}" $@
	else
		command fastfetch -l "${logos[$RANDOM % ${#logos[@]}]}" $@
	fi
}

neofetch() {
	fastfetch $@
}

# Create a directory and cd into it directly
mkcd() {
	mkdir "$*"
	cd "$*"
}

# Cd into directory and list its contents
cdl() {
	cd "$*"
	ls
}

# +-------------+
# | Git Aliases |
# +-------------+

# Git add all files and commit with message following "gg". Example: "gg My commit message"
# Only adds modified and deleted files, not untracked ones
gg() {
	# "git add" is obsolete, done with the -a below
	#git add . 
	git commit -am "$*"
}

