# queue up commands inside of a text file from multiple sessions and execute them one by one in the first session
# usage: q name <command> <arguments>
# code is AI generated
q() {
# check for missing arguments
	if [[ $# -le 1 ]]; then
		echo "Usage: q <file_name> <command> [args...]"
		return 1
	fi

	# check if $1 is a command but not equal to $2 (probably wrong usage)
	if command -v "$1" >/dev/null 2>&1 && [[ "$1" != "$2" ]]; then
		echo "Usage: q <file_name> <command> [args...]"
		echo "Did you mean: q <file_name> $* ?"
		return 1
	fi

	# all validation passed - proceed with actual functionality
	local file="$HOME/$1.q.up"
	shift # remove the first parameter (the file name)
	local cmd="$*"

	if [[ ! -f "$file" ]]; then
		# file doesn't exist, create it and execute the command
		touch "$file"
		eval "$cmd"
		# continuously process the file until it's empty
		while [[ -s $file ]]; do
			# read and execute the first line
			local line=$(head -n 1 "$file")
			# remove the executed line from the file
			sed -i '1d' "$file"
			eval "$line"
		done
		# remove the file if it's empty
		rm "$file"
	else
		# file exists, append the command to the file
		echo "$cmd" >> "$file"
	fi
}

# list downloaded LLMs on ollama and easily run one by prompting
# code is AI generated
os() {
	# retrieve and save the output of "ollama list" in a variable
	output=$(ollama list)

	# print the output with line numbers for each line except the header
	echo "$output" | awk 'NR==1 {print; next} {print NR-1, $0}'

	# get the number of models (subtracting header line)
	num_models=$(echo "$output" | wc -l)
	num_models=$((num_models - 1))

	# prompt user for input and validate choice
	while true; do
		echo -n "\nEnter the number of the model you want to run (1-$num_models): "
		read choice
		if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= num_models )); then
			break
		else
			echo "Invalid choice. Please enter a number between 1 and $num_models."
		fi
	done

	# extract the name of the selected model based on user choice
	model_name=$(echo "$output" | awk -v line=$((choice + 1)) 'NR == line {print $1}')

	# run the chosen model using "ollama run <model_name>"
	ollama run "$model_name"
}
