# open tldr page when argument is given, fuzzy seach when run without arguments
# uses "command" to prevent recursive alias expansion and actually call /usr/bin/tldr
tldr() {
	if [ "$#" -eq 0 ]; then
		command tldr --list | fzf --preview "command tldr {} --color always" | xargs -r tldr
	else
		command tldr $@
	fi
}

yt-dlp() {
	if [ "$#" -eq 1 ]; then
		# if given exactly one argument, download that video in mp4 by default
		command yt-dlp -t mp4 $@
	else
		command yt-dlp $@
	fi
}

gputest() {
	ensure_installed furmark
	furmark --demo furmark-knot-vk --fullscreen --p1080
}

cputest() {
	ensure_installed stress
	stress --cpu $(nproc)
}

fastfetch() {
	ensure_installed fastfetch
	# give a bit more weight to arch and the cool wolf from darkos
	logos=("arch2" "arch2" "darkos" "darkos" "fastfetch" "locos" "sulin")

	# indexing works fine for most shells, including bash, zsh arrays start at 1 however
	if [[ -n "$ZSH_VERSION" ]]; then
		command fastfetch -l "${logos[$(($RANDOM % ${#logos[@]} + 1))]}" $@
	else
		command fastfetch -l "${logos[$RANDOM % ${#logos[@]}]}" $@
	fi
}

neofetch() {
	fastfetch $@
}

# create a directory and cd into it directly
