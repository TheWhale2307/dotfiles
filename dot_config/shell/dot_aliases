# install a package if it is not yet installed
ensure_installed() {
	for package in "$@"; do
		if ! paru -Qi "$package" >/dev/null 2>&1; then
			echo "WARNING: $package is missing! Trying to install..."
			paru -S --noconfirm "$package"
		fi
	done
}

# update the entire system with paru (and flatpak)
uu() {
	printf "\n\033[53;4m--- Paru ---\033[0m\n\n"
	paru -Syu --noconfirm --sudoloop --newsonupgrade --ignore openrgb
	if paru -Qi "flatpak" >/dev/null 2>&1; then
		printf "\n\033[53;4m--- Flatpak ---\033[0m\n\n"
		flatpak update -y
	fi
}

